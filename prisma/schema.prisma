generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Pipeline {
  id                   String        @id @default(cuid())
  name                 String
  owner                String
  env                  String
  lastRunStatus        String
  lastRunDurationSec   Int
  updatedAt            DateTime      @updatedAt
  runs                 PipelineRun[]
}

model PipelineRun {
  id           String          @id @default(cuid())
  pipelineId   String
  startedAt    DateTime
  endedAt      DateTime?
  status       String
  durationSec  Int
  pipeline     Pipeline        @relation(fields: [pipelineId], references: [id])
  stages       PipelineStage[]
  insights     Insight[]       @relation("PipelineRunInsights")
}

model PipelineStage {
  id            String        @id @default(cuid())
  pipelineRunId String
  name          String
  status        String
  startedAt     DateTime
  endedAt       DateTime?
  errorCode     String?
  errorSummary  String?
  run           PipelineRun   @relation(fields: [pipelineRunId], references: [id])
}

model AlertGroup {
  id         String          @id @default(cuid())
  name       String
  service    String
  env        String
  severity   String
  count      Int
  lastSeenAt DateTime
  status     String
  instances  AlertInstance[]
  insights   Insight[]       @relation("AlertGroupInsights")
}

model AlertInstance {
  id           String     @id @default(cuid())
  alertGroupId String
  timestamp    DateTime
  message      String
  fingerprint  String
  group        AlertGroup @relation(fields: [alertGroupId], references: [id])
}

model Incident {
  id         String          @id @default(cuid())
  title      String
  env        String
  severity   String
  status     String
  startedAt  DateTime
  resolvedAt DateTime?
  owner      String
  events     IncidentEvent[]
  insights   Insight[]       @relation("IncidentInsights")
}

model IncidentEvent {
  id         String   @id @default(cuid())
  incidentId String
  timestamp  DateTime
  type       String
  message    String
  incident   Incident @relation(fields: [incidentId], references: [id])
}

model Insight {
  id              String   @id @default(cuid())
  entityType      String
  entityId        String
  rootCauseJson   String
  confidence      String
  suggestedFixJson String
  riskImpact      String
  createdAt       DateTime @default(now())
  pipelineRun     PipelineRun? @relation("PipelineRunInsights", fields: [entityId], references: [id], map: "pipeline_run_fk")
  alertGroup      AlertGroup?  @relation("AlertGroupInsights", fields: [entityId], references: [id], map: "alert_group_fk")
  incident        Incident?    @relation("IncidentInsights", fields: [entityId], references: [id], map: "incident_fk")
}
