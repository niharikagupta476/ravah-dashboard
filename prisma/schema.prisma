generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Pipeline {
  id          String        @id @default(cuid())
  orgId       String
  projectId   String
  name        String
  service     String
  provider    String   @default("github-actions")
  repo        String   @default("unknown/repo")
  branch      String   @default("main")
  env         String
  status      String
  lastRunAt   DateTime
  durationSec Int
  owner       String
  org         Organization  @relation(fields: [orgId], references: [id])
  project     Project       @relation(fields: [projectId], references: [id])
  runs        PipelineRun[]
}

model PipelineRun {
  id         String   @id @default(cuid())
  pipelineId String
  orgId      String
  projectId  String
  status     String
  startedAt  DateTime
  endedAt    DateTime?
  logsText   String
  duration   Int      @default(0)
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id])
  org        Organization @relation(fields: [orgId], references: [id])
  project    Project @relation(fields: [projectId], references: [id])
  stages     Stage[]
  jobs       Job[]
}

model Stage {
  id            String      @id @default(cuid())
  pipelineRunId String
  orgId         String
  projectId     String
  name          String
  status        String
  errorCode     String?
  errorMessage  String?
  duration      Int      @default(0)
  run           PipelineRun @relation(fields: [pipelineRunId], references: [id])
  org           Organization @relation(fields: [orgId], references: [id])
  project       Project @relation(fields: [projectId], references: [id])
}



model Job {
  id            String      @id @default(cuid())
  pipelineRunId String
  orgId         String
  projectId     String
  name          String
  status        String
  logs          String
  duration      Int         @default(0)
  run           PipelineRun @relation(fields: [pipelineRunId], references: [id])
  org           Organization @relation(fields: [orgId], references: [id])
  project       Project     @relation(fields: [projectId], references: [id])
}
model Insight {
  id               String   @id @default(cuid())
  entityType       String
  entityId         String
  orgId            String
  projectId        String
  rootCause        String
  confidence       String
  suggestedFixJson String
  riskImpact       String
  relatedChange    String
  createdAt        DateTime @default(now())
  org              Organization @relation(fields: [orgId], references: [id])
  project          Project @relation(fields: [projectId], references: [id])

  @@index([entityType, entityId])
}

model Activity {
  id         String   @id @default(cuid())
  orgId      String
  projectId  String
  message    String
  createdAt  DateTime @default(now())
  entityType String
  entityId   String
  org        Organization @relation(fields: [orgId], references: [id])
  project    Project @relation(fields: [projectId], references: [id])
}

model Organization {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  createdAt   DateTime     @default(now())
  memberships Membership[]
  projects    Project[]
  pipelines   Pipeline[]
  pipelineRuns PipelineRun[]
  stages      Stage[]
  jobs        Job[]
  insights    Insight[]
  activities  Activity[]
  integrations IntegrationGithub[]
}

// NextAuth Prisma adapter expects this User shape.
// Keep provider identifiers (like GitHub account IDs) in Account.providerAccountId,
// not custom User.githubId columns, to avoid adapter lifecycle mismatches.
model User {
  id            String       @id @default(cuid())
  name          String?
  email         String?      @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime     @default(now())
  memberships   Membership[]
  accounts      Account[]
  sessions      Session[]
}

model Membership {
  id     String @id @default(cuid())
  userId String
  orgId  String
  role   String
  user   User @relation(fields: [userId], references: [id])
  org    Organization @relation(fields: [orgId], references: [id])
}

model Project {
  id        String   @id @default(cuid())
  orgId     String
  name      String
  repoOwner String
  repoName  String
  createdAt DateTime @default(now())
  org       Organization @relation(fields: [orgId], references: [id])
  pipelines Pipeline[]
  pipelineRuns PipelineRun[]
  stages    Stage[]
  jobs      Job[]
  insights  Insight[]
  activities Activity[]
  integrations IntegrationGithub[]
}

model IntegrationGithub {
  id                 String   @id @default(cuid())
  orgId              String
  projectId          String?
  type               String
  accessTokenEncrypted String?
  installationId     String?
  createdAt          DateTime @default(now())
  org                Organization @relation(fields: [orgId], references: [id])
  project            Project? @relation(fields: [projectId], references: [id])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
model AlertGroup {
  id         String          @id @default(cuid())
  name       String
  service    String
  env        String
  severity   String
  count      Int
  lastSeenAt DateTime
  status     String
  instances  AlertInstance[]
}

model AlertInstance {
  id           String     @id @default(cuid())
  alertGroupId String
  timestamp    DateTime
  message      String
  fingerprint  String
  group        AlertGroup @relation(fields: [alertGroupId], references: [id])
}

model Incident {
  id         String          @id @default(cuid())
  title      String
  env        String
  severity   String
  status     String
  startedAt  DateTime
  resolvedAt DateTime?
  owner      String
  events     IncidentEvent[]
}

model IncidentEvent {
  id         String   @id @default(cuid())
  incidentId String
  timestamp  DateTime
  type       String
  message    String
  incident   Incident @relation(fields: [incidentId], references: [id])
}
